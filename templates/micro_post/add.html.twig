{# templates/micro_post/add.html.twig #}
{% extends 'base.html.twig' %}
{% form_theme form 'form/tailwind_layout.html.twig' %}

 {# --- ZARİF HATA MESAJLARI TASARIMI BAŞLANGICI --- #}
{% block form_errors %}
    {% if errors|length > 0 %}
        <ul class="mt-1.5 flex flex-col gap-1 pl-1">
            {% for error in errors %}
                <li class="flex items-center gap-1.5 text-sm font-medium text-red-500 dark:text-red-400 transition-colors">
                    <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                    {{ error.message }}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock form_errors %}
{# --- ZARİF HATA MESAJLARI TASARIMI BİTİŞİ --- #} 

{% block title %}Yeni Günlük Paylaşımı{% endblock %}

{% block body %}
<div x-data="{ 
        category: 'learning',
        titles: {
            'learning': 'Yeni Öğrenme Günlüğü',
            'internship': 'Yeni Staj Günlüğü',
            'work': 'Yeni İş Günlüğü',
            'personal': 'Yeni Normal Günlük'
        },
        descriptions: {
            'learning': 'Bugün öğrendiğin o harika şeyi ölümsüzleştir.',
            'internship': 'Stajındaki deneyimlerini, öğrendiklerini ve görevlerini kaydet.',
            'work': 'İş hayatındaki gününü, başarılarını ve notlarını anlat.',
            'personal': 'Bugün neler yaşadın? Düşüncelerini ve hislerini paylaş.'
        },
        inputPlaceholders: {
            'learning': 'Örn: Bugün Symfony Öğrendim!',
            'internship': 'Örn: Stajda 1. Gün - İlk Görev',
            'work': 'Örn: Proje Tamamlandı',
            'personal': 'Örn: Harika Bir Hafta Sonu'
        },
        textareaPlaceholders: {
            'learning': 'Bugün neler öğrendin? Detaylandır...',
            'internship': 'Bugün stajda hangi görevleri yaptın?',
            'work': 'İşyerindeki başarın veya düşüncelerin neler?',
            'personal': 'Düşüncelerini ve hislerini yaz...'
        }
    }" 
    x-init="
        const catSelect = document.getElementById('micro_post_category');
        const titleInput = document.getElementById('micro_post_title');
        const textInput = document.getElementById('micro_post_text');
        
        const updateForm = (val) => {
            category = val;
            if(titleInput) titleInput.placeholder = inputPlaceholders[val];
            if(textInput) textInput.placeholder = textareaPlaceholders[val];
        };

        if(catSelect) {
            updateForm(catSelect.value);
            catSelect.addEventListener('change', (e) => {
                updateForm(e.target.value);
            });
        }
    "
    class="max-w-2xl mx-auto py-10 px-4 sm:px-6">
    
    {# 1. Navigasyon (Breadcrumb) #}
    <div class="mb-8">
        {{ include('_breadcrumb.html.twig', {'current_page': 'Yeni Paylaşım'}) }}
    </div>

    {# 2. Ana Kart Yapısı #}
    <div class="bg-white dark:bg-gray-800 shadow-2xl rounded-3xl overflow-hidden border border-gray-100 dark:border-gray-700 transition-all duration-300">
        
        {# Kart Üst Kısmı #}
        <div class="p-8 border-b border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50">
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">
                <span class="text-blue-600 dark:text-blue-400" x-text="titles[category]">Yeni Paylaşım</span>
            </h1>
            <p class="mt-2 text-gray-500 dark:text-gray-400 text-sm" x-text="descriptions[category]">
                Deneyimlerini paylaş.
            </p>
        </div>

        {# 3. Form Alanı #}
        <div class="p-8">
            {{ include('micro_post/_form.html.twig', { 'form': form }, {'button_label': 'Günlüğü Yayınla'}) }}
        </div>

        {# Kart Alt Kısmı (Vazgeç Butonu) #}
        <div class="px-8 py-6 bg-gray-50 dark:bg-gray-800/80 border-t border-gray-100 dark:border-gray-700 flex justify-center">
            <a href="{{ path('app_micro_post') }}" class="text-sm font-medium text-gray-500 hover:text-red-500 dark:text-gray-400 dark:hover:text-red-400 transition-colors flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Vazgeç ve Listeye Dön
            </a>
        </div>
    </div>
</div>
{% endblock %}