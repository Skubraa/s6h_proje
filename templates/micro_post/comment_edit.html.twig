{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-xl mx-auto mt-10 p-6 bg-white shadow-lg rounded-2xl border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b pb-4">Yorumu Düzenle</h2>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="mb-6">
                {{ form_label(form.text, 'Yorumun', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                {{ form_widget(form.text, {
                    'attr': {
                        'class': 'w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 outline-none transition duration-200',
                        'rows': '4'
                    }
                }) }}
                <div class="text-red-500 text-sm mt-1">
                    {{ form_errors(form.text) }}
                </div>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-6 rounded-lg transition duration-200 shadow-md">
                    Güncelle
                </button>
                <a href="{{ path('app_micro_post_show', {id: comment.post.id}) }}" class="text-slate-500 hover:text-slate-700 text-sm font-medium">
                    Vazgeç
                </a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}