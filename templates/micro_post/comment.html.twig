{# Tek bir yorumun tüm dünyası burası #}
<div class="bg-white dark:bg-gray-800 p-5 rounded-2xl border border-slate-100 dark:border-gray-700 shadow-sm hover:shadow-md transition-all duration-300 group">
    <div class="flex justify-between items-start">
        
        {# 1. READ (GÖRÜNTÜLEME) KISMI #}
        <div class="flex-1">
            <div class="flex items-center gap-2 mb-2">

                {# YENİ: Yorum Yazarının Avatarı #}
                {{ include('shared/_avatar.html.twig', {'size': 8, profile: comment.author.userProfile}) }}

                {# DİNAMİK YAZAR BİLGİSİ #}
                <a href="{{ path('app_profile', {id: comment.author.id}) }}" class="font-bold text-indigo-600 dark:text-indigo-400 text-sm hover:underline">
                    @{{ comment.author.userProfile.name|default(comment.author.email|split('@')[0]) }}
                </a>
                <span class="text-slate-300 text-xs">•</span>
                {# DİNAMİK TARİH #}
                <span class="text-slate-400 text-xs italic">
                    {{ comment.created|date("d.m.Y H:i") }}
                </span>
            </div>
            
            <p class="text-slate-700 dark:text-gray-300 leading-relaxed">
                {{ comment.text }}
            </p>
        </div>

        {# 2. UPDATE & DELETE AKSİYONLARI #}
        {# Güvenlik Notu: Sadece yorum sahibi veya admin düzenleyebilir/silebilir #}
        {% if is_granted('COMMENT_EDIT', comment) or is_granted('ROLE_ADMIN') %}
        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
            
            <a href="{{ path('app_comment_edit', {id: comment.id}) }}" 
               class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 dark:hover:bg-gray-700 rounded-xl transition-all" 
               title="Düzenle">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
            </a>

            <form method="post" action="{{ path('app_comment_delete', {id: comment.id}) }}" 
                  onsubmit="return confirm('Bu yorumu sonsuza dek silmek istediğine emin misin?');" class="m-0">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
                <button type="submit" 
                        class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-xl transition-all" 
                        title="Sil">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                </button>
            </form>
        </div>
        {% endif %}
    </div>
</div>