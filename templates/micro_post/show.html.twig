{# templates/micro_post/show.html.twig #}
{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-2xl mx-auto mt-10 px-4 md:px-0">
        {# ANA POST KARTI #}
        <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100 p-6 md:p-8">
            
            {# Başlık ve Beğeni Butonunu kapsayan ana Flex div #}
            <div class="flex items-center justify-between gap-4 mb-2">
                <h2 class="text-3xl font-bold text-blue-600">
                    {{ post.title }}
                </h2>

                {# Beğeni Butonu Alanı #}
                <div class="flex items-center">
                    <a href="{{ path('app_micro_post_like', {id: post.id}) }}" 
                       class="flex items-center gap-1.5 group transition-all transform hover:scale-110 active:scale-95">
                        
                        {# Kalp İkonu #}
                        <svg xmlns="http://www.w3.org/2000/svg" 
                            class="h-8 w-8 {{ app.user in post.likedBy ? 'text-red-500 fill-current' : 'text-slate-300' }} group-hover:text-red-400 transition-colors" 
                            fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>

                        {# Beğeni Sayısı #}
                        <span class="text-lg font-bold {{ app.user in post.likedBy ? 'text-red-600' : 'text-slate-500' }}">
                            {{ post.likedBy|length }}
                        </span>
                    </a>
                </div>
            </div>

            {# YAZAR VE TARİH BİLGİSİ #}
            <div class="flex items-center gap-3 mb-6">
                
                {# 1. Post Yazarının Avatarı #}
                {{ include('shared/_avatar.html.twig', {'size': 12, profile: post.author.userProfile}) }}
                
                <div class="flex flex-col">
                    {# Yazarın Adı ve Profile Gitme Linki #}
                    <a href="{{ path('app_profile', {id: post.author.id}) }}" class="text-sm font-bold text-gray-900 dark:text-white hover:text-blue-600 transition-colors">
                        {{ post.author.userProfile.name|default(post.author.email|split('@')[0]) }}
                    </a>
                    
                    {# Tarih Bilgisi (Küçültülüp ismin altına alındı) #}
                    <p class="text-gray-400 text-xs italic flex items-center gap-1 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        {{ post.created|date('d.m.Y H:i') }}
                    </p>
                </div>
            </div>

            {# Post Metni #}
            <p class="text-gray-700 leading-relaxed text-lg mb-8">
                {{ post.text }}
            </p>

            {% if post.category == 'internship' %}
                <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 p-4">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                        <div>
                            <h3 class="text-base font-bold text-emerald-950">Günlük staj raporu</h3>
                            <p class="text-sm text-emerald-700 mt-1">Bu paylaşımındaki çalışmaları kısa bir rapor taslağına dönüştür.</p>
                        </div>

                        {% if is_granted('POST_EDIT', post) %}
                            <form method="post" action="{{ path('app_micro_post_internship_report', {id: post.id}) }}" class="m-0">
                                <input type="hidden" name="_token" value="{{ csrf_token('internship_report' ~ post.id) }}">
                                <button type="submit" class="inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2.5 px-5 rounded-xl shadow-sm transition-all duration-200 focus:outline-none focus:ring-4 focus:ring-emerald-500/30 whitespace-nowrap">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    Staj Raporu Oluştur
                                </button>
                            </form>
                        {% else %}
                            <span class="text-sm font-semibold text-emerald-700">Raporu sadece paylaşım sahibi oluşturabilir.</span>
                        {% endif %}
                    </div>

                    {% if internship_report is defined and internship_report %}
                        <div id="internship-report-output" class="mt-5 rounded-xl border border-emerald-300 bg-white p-5 shadow-sm">
                            <div class="flex items-center justify-between gap-3 mb-3">
                                <h3 class="text-lg font-bold text-emerald-900">AI Günlük Staj Raporu</h3>
                                <span class="text-xs font-semibold text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-full px-3 py-1">Taslak</span>
                            </div>
                            <textarea readonly rows="7" class="w-full resize-y rounded-lg border border-emerald-200 bg-emerald-50/60 p-4 text-emerald-950 leading-relaxed focus:outline-none focus:ring-2 focus:ring-emerald-500">{{ internship_report }}</textarea>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {# AKSİYON BUTONLARI - Sadece yetkisi olana görünür #}
            {% if is_granted('POST_EDIT', post) %}
                <div class="flex items-center gap-4 border-t pt-6 mb-6">
                    <form method="post" action="{{ path('app_micro_post_delete', {id: post.id}) }}" 
                        onsubmit="return confirm('Bu içeriği silmek istediğine emin misin?');" class="m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                        <button class="bg-slate-100 hover:bg-red-50 text-slate-600 hover:text-red-600 font-semibold py-2 px-6 rounded-xl transition-all duration-300 border border-slate-200">
                            Sil
                        </button>
                    </form>

                    <a href="{{ path('app_micro_post_edit', {id: post.id}) }}" 
                    class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-xl shadow-md transition-all duration-300">
                        Düzenle
                    </a>
                </div>
            {% endif %}

            {# Geri Dön Butonu - Her zaman görünür ve kartın içinde #}
            <div class="flex border-t pt-4 mt-4">
                <a href="{{ path('app_micro_post') }}" class="text-slate-400 hover:text-indigo-600 font-medium flex items-center gap-1 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Geri Dön
                </a>
            </div>
            
        </div>

        {# YORUM YAPMA ALANI #}
        <div class="mt-8 bg-gray-50 rounded-2xl border border-gray-200 p-6 shadow-sm">
            <h3 class="text-xl font-bold text-gray-800 mb-4">
                {% if post.category == 'learning' %}Öğrenme Günlüğüne Yorum Bırak
                {% elseif post.category == 'internship' %}Staj Günlüğüne Yorum Bırak
                {% elseif post.category == 'work' %}İş Günlüğüne Yorum Bırak
                {% elseif post.category == 'personal' %}Bu Günlüğe Yorum Bırak
                {% else %}Bir Yorum Bırak{% endif %}
            </h3>
            
            {{ form_start(comment_form, {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="mb-4">
                    {{ form_widget(comment_form.text, {
                        'attr': {
                            'class': 'w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition duration-200 bg-white',
                            'placeholder': 
                                post.category == 'learning' ? 'Bu öğrenme günlüğü hakkında ne düşünüyorsun?' :
                                (post.category == 'internship' ? 'Staj deneyimi hakkında ne düşünüyorsun?' :
                                (post.category == 'work' ? 'İş hayatındaki bu durum hakkında ne düşünüyorsun?' :
                                (post.category == 'personal' ? 'Bu günlük hakkında düşüncelerini yaz...' :
                                'Neler düşünüyorsun?'))),
                            'rows': '3'
                        }
                    }) }}
                    <div class="text-red-500 text-sm mt-1">
                        {{ form_errors(comment_form.text) }}
                    </div>
                </div>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-8 rounded-xl transition-all shadow-sm">
                    Yorumu Gönder
                </button>
            {{ form_end(comment_form) }}
        </div>

        
        {# YORUMLARI LİSTELEME #}
        <div class="mt-8 mb-20">
            <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-4 border-b dark:border-gray-700 pb-2">
                Yorumlar <span class="text-blue-600">({{ post.comments|length }})</span>
            </h3>
            
            <div class="space-y-4">
                {% for comment in post.comments %}
                    <div class="bg-white dark:bg-gray-800 p-5 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm group hover:border-blue-200 transition-all duration-200">
                        
                        {# 1. YAZAR BİLGİSİ VE TAKİP BUTONU #}
                        <div class="flex items-center justify-between mb-3 pb-3 border-b border-gray-50 dark:border-gray-700/50">
                            <div class="flex items-center gap-3">
                                {# YENİ: Yorum yazarının dinamik avatarı #}
                                {{ include('shared/_avatar.html.twig', {'size': 10, profile: comment.author.userProfile}) }}
                                
                                <div class="flex flex-col">
                                    {# Yazar Adı #}
                                    <a href="{{ path('app_profile', {id: comment.author.id}) }}" class="text-sm font-bold text-gray-900 dark:text-white hover:text-blue-600 transition-colors">
                                        {{ comment.author.userProfile.name|default(comment.author.email|split('@')[0]) }}
                                    </a>
                                    {# Tarih #}
                                    <div class="text-[10px] text-gray-400 italic flex items-center gap-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        {{ comment.created|date("d.m.Y H:i") }}
                                    </div>
                                </div>
                            </div>

                            {# TAKİP BUTONU: Bilgisayar mühendisi titizliğiyle sağ tarafa, ferah bir yere aldık #}
                            <div class="shrink-0">
                                {{ include('follower/_follow_button.html.twig', { userToFollow: comment.author }) }}
                            </div>
                        </div>

                        {# YORUM METNİ #}
                        <div class="flex justify-between items-start gap-4">
                            <div class="flex-1">
                                <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{{ comment.text }}</p>
                            </div>

                            {# 2. DÜZENLE / SİL AKSİYONLARI #}
                            {# Voter yoksa hata almamak için ID karşılaştırması ekledim #}
                            {% if is_granted('COMMENT_EDIT', comment) or (app.user and comment.author.id == app.user.id) %}
                                {# opacity-0 olduğu için mouse ile üzerine gelince görünür #}
                                <div class="flex items-center gap-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200 shrink-0">
                                    <a href="{{ path('app_comment_edit', {id: comment.id}) }}" class="text-blue-400 hover:text-blue-600 text-sm font-medium">Düzenle</a>
                                    
                                    <form method="post" action="{{ path('app_comment_delete', {id: comment.id}) }}" onsubmit="return confirm('Silmek istediğine emin misin?');" class="m-0">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
                                        <button type="submit" class="text-slate-300 hover:text-red-500 text-sm font-medium transition-colors">Sil</button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-2xl border-2 border-dashed border-gray-200 dark:border-gray-700">
                        <p class="text-gray-400 italic">
                            {% if post.category == 'learning' %}Henüz yorum yapılmamış. Öğrenme günlüğüne ilk yorumu sen yap!
                            {% elseif post.category == 'internship' %}Staj günlüğüne henüz yorum yapılmamış. İlk yorumu sen ekle!
                            {% elseif post.category == 'work' %}İş günlüğüne henüz yorum yapılmamış. Düşüncelerini paylaş!
                            {% elseif post.category == 'personal' %}Henüz yorum yok. İlk yorumu sen yap!
                            {% else %}Henüz yorum yapılmamış. İlk yorumu sen yap!{% endif %}
                        </p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
