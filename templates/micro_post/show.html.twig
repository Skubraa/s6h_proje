{# templates/micro_post/show.html.twig #}
{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-2xl mx-auto mt-10 px-4 md:px-0">
        {# ANA POST KARTI #}
        <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100 p-6 md:p-8">
            
            {# Başlık ve Beğeni Butonunu kapsayan ana Flex div #}
            <div class="flex items-center justify-between gap-4 mb-2">
                <h2 class="text-3xl font-bold text-blue-600">
                    {{ post.title }}
                </h2>

                {# Beğeni Butonu Alanı #}
                <div class="flex items-center">
                    <a href="{{ path('app_micro_post_like', {id: post.id}) }}" 
                       class="flex items-center gap-1.5 group transition-all transform hover:scale-110 active:scale-95">
                        
                        {# Kalp İkonu #}
                        <svg xmlns="http://www.w3.org/2000/svg" 
                            class="h-8 w-8 {{ app.user in post.likedBy ? 'text-red-500 fill-current' : 'text-slate-300' }} group-hover:text-red-400 transition-colors" 
                            fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>

                        {# Beğeni Sayısı #}
                        <span class="text-lg font-bold {{ app.user in post.likedBy ? 'text-red-600' : 'text-slate-500' }}">
                            {{ post.likedBy|length }}
                        </span>
                    </a>
                </div>
            </div>

            {# Tarih Bilgisi #}
            <p class="text-gray-400 text-sm mb-6 italic flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Oluşturulma: {{ post.created|date('d.m.Y H:i') }}
            </p>

            {# Post Metni #}
            <p class="text-gray-700 leading-relaxed text-lg mb-8">
                {{ post.text }}
            </p>

            {# AKSİYON BUTONLARI - Sadece yetkisi olana görünür #}
            {% if is_granted('POST_EDIT', post) %}
                <div class="flex items-center gap-4 border-t pt-6 mb-6">
                    <form method="post" action="{{ path('app_micro_post_delete', {id: post.id}) }}" 
                        onsubmit="return confirm('Bu içeriği silmek istediğine emin misin?');" class="m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                        <button class="bg-slate-100 hover:bg-red-50 text-slate-600 hover:text-red-600 font-semibold py-2 px-6 rounded-xl transition-all duration-300 border border-slate-200">
                            Sil
                        </button>
                    </form>

                    <a href="{{ path('app_micro_post_edit', {id: post.id}) }}" 
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-6 rounded-xl shadow-md transition-all duration-300">
                        Düzenle
                    </a>
                </div>
            {% endif %}

            {# Geri Dön Butonu - Her zaman görünür ve kartın içinde #}
            <div class="flex border-t pt-4 mt-4">
                <a href="{{ path('app_micro_post') }}" class="text-slate-400 hover:text-indigo-600 font-medium flex items-center gap-1 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Geri Dön
                </a>
            </div>
            
        </div>

        {# YORUM YAPMA ALANI #}
        <div class="mt-8 bg-gray-50 rounded-2xl border border-gray-200 p-6 shadow-sm">
            <h3 class="text-xl font-bold text-gray-800 mb-4">Bir Yorum Bırak</h3>
            
            {{ form_start(comment_form, {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="mb-4">
                    {{ form_widget(comment_form.text, {
                        'attr': {
                            'class': 'w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition duration-200 bg-white',
                            'placeholder': 'Neler düşünüyorsun?',
                            'rows': '3'
                        }
                    }) }}
                    <div class="text-red-500 text-sm mt-1">
                        {{ form_errors(comment_form.text) }}
                    </div>
                </div>
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-8 rounded-xl transition-all shadow-sm">
                    Yorumu Gönder
                </button>
            {{ form_end(comment_form) }}
        </div>

        {# YORUMLARI LİSTELEME #}
        <div class="mt-8 mb-20">
            <h3 class="text-xl font-bold text-gray-800 mb-4 border-b pb-2">
                Yorumlar <span class="text-indigo-600">({{ post.comments|length }})</span>
            </h3>
            
            <div class="space-y-4">
                {% for comment in post.comments %}
                    <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm group hover:border-indigo-200 transition-all duration-200">
                        <div class="flex justify-between items-start">
                            <div class="flex-1">
                                <p class="text-gray-700 leading-relaxed">{{ comment.text }}</p>
                                <div class="mt-3 text-xs text-gray-400 italic flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    {{ comment.created|date("d.m.Y H:i") }}
                                </div>
                            </div>

                            {% if is_granted('POST_EDIT', post) or comment.author == app.user %}
                                <div class="flex items-center gap-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                                    <a href="{{ path('app_comment_edit', {id: comment.id}) }}" class="text-indigo-400 hover:text-indigo-600 text-sm font-medium">Düzenle</a>
                                    <form method="post" action="{{ path('app_comment_delete', {id: comment.id}) }}" onsubmit="return confirm('Silmek istediğine emin misin?');" class="m-0">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
                                        <button type="submit" class="text-slate-300 hover:text-red-500 text-sm font-medium transition-colors">Sil</button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="text-center py-12 bg-white rounded-2xl border-2 border-dashed border-gray-200">
                        <p class="text-gray-400 italic">Henüz yorum yapılmamış. İlk yorumu sen yap!</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}