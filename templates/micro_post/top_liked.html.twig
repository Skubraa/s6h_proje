{# micro_post/top_liked.html.twig veya follows.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}En Çok Beğenilen Paylaşımlar{% endblock %}

{% block body %}
    {# 1. Breadcrumb ve Başlık Alanını kapsayan ana div #}
    <div class="max-w-5xl mx-auto px-4"> 
        <div class="mb-8">
            {{ include('_breadcrumb.html.twig', {'current_page': 'En Çok Beğenilen Paylaşımlar'}) }}
        </div>

        {# 2. Sekmeler #}
        {{ include('micro_post/_post_tabs.html.twig') }}

        {# 3. Post Listesi #}
        <div class="mt-8">
            {{ include('micro_post/_post_list.html.twig', { posts: posts }) }}
        </div>
    </div>
{% endblock %}