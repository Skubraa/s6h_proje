{# Tüm kartı bir link haline getiriyoruz (Z-index yönetimiyle) #}
<div class="relative bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-lg sm:rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden group">
    
    {# Görünmez Link: Tüm kartın üzerine tıklandığında detaya gitmesi için #}
    <a href="{{ path('app_micro_post_show', {id: post.id}) }}" class="absolute inset-0 z-10"></a>

    <div class="p-6 md:p-8 relative z-20 pointer-events-none">
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-2 md:gap-0">
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-tight">
                        {{ post.title }}
                    </h3>
                </div>

                {# Yazar Bilgisi (pointer-events-auto ekledik ki profil linki çalışsın) #}
                <div class="mb-2 pointer-events-auto">
                    <a href="{{ path('app_profile', {id: post.author.id}) }}" 
                    class="inline-flex items-center gap-1.5 text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline">
                        <div class="w-5 h-5 bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 rounded-full flex items-center justify-center text-[10px] font-bold">
                            {{ post.author.userProfile.name|default(post.author.email)|first|upper }}
                        </div>
                        {{ post.author.userProfile.name|default(post.author.email|split('@')[0]) }}
                    </a>
                </div>
                
                <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400 mt-2">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        {{ post.created|date('d.m.Y H:i') }}
                    </span>
                    
                    {% if post.comments|length > 0 %}
                        <span class="flex items-center gap-1 text-indigo-500 dark:text-indigo-400 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                            </svg>
                            {{ post.comments|length }}
                        </span>
                    {% endif %}
                </div>
            </div>
            
            {# Kalp İkonu (Günlük yazısı yerine buraya geldi) #}
            <div class="pointer-events-auto">
                <a href="{{ path('app_micro_post_like', {id: post.id}) }}" class="flex items-center gap-1.5 group transition-all shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" 
                        class="h-6 w-6 {{ app.user in post.likedBy ? 'text-red-500 fill-current' : 'text-gray-400 group-hover:text-red-500' }} transition-colors" 
                        fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>

                    {% if post.likedBy|length > 0 %}
                        <span class="text-base font-bold {{ app.user in post.likedBy ? 'text-red-600' : 'text-gray-500 group-hover:text-red-600' }}">
                            {{ post.likedBy|length }}
                        </span>
                    {% endif %}
                </a>
            </div>
        </div>

        <p class="mt-6 text-gray-700 dark:text-gray-300 leading-relaxed text-base md:text-lg">
            {{ post.text|length > 180 ? post.text|slice(0, 180) ~ '...' : post.text }}
        </p>

        {# Alt Bölüm: Devamını oku kalktı, sadece düzenle butonu kaldı #}
        {% if is_granted('POST_EDIT', post) %}
            <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700 flex justify-end pointer-events-auto">
                <a href="{{ path('app_micro_post_edit', {id: post.id}) }}" 
                class="text-gray-500 dark:text-gray-400 hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors p-2 rounded-lg hover:bg-yellow-50 dark:hover:bg-gray-700"
                title="Düzenle">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                </a>
            </div>
        {% endif %}
    </div>
</div>