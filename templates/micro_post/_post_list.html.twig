{# Post Listesi #}
    <div class="space-y-8">
        {% for post in posts %}
            {{ include('micro_post/_post.html.twig', { post: post }) }}
        {% else %}
            <div class="flex flex-col items-center justify-center py-20 px-6 bg-gradient-to-b from-gray-50 to-white dark:from-gray-800 dark:to-gray-900 rounded-3xl border border-gray-100 dark:border-gray-700 shadow-sm mt-8">
                <div class="bg-indigo-50 dark:bg-gray-700/50 p-6 rounded-full mb-6">
                    <svg class="w-12 h-12 text-indigo-400 dark:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
                </div>
                <p class="text-xl font-bold text-gray-800 dark:text-gray-200 mb-2">
                    {% if active_category is defined %}
                        {% if active_category == 'learning' %}Henüz bir öğrenme günlüğü paylaşılmamış...
                        {% elseif active_category == 'internship' %}Henüz bir staj günlüğü paylaşılmamış...
                        {% elseif active_category == 'work' %}Henüz bir iş günlüğü paylaşılmamış...
                        {% elseif active_category == 'personal' %}Henüz normal bir günlük paylaşılmamış...
                        {% else %}Henüz hiçbir şey paylaşılmamış...{% endif %}
                    {% else %}
                        Henüz hiçbir şey paylaşılmamış...
                    {% endif %}
                </p>
                <p class="text-gray-500 dark:text-gray-400 text-center max-w-md mb-8">İlk adımı sen at ve yeni bir paylaşım oluşturarak günlüğünü başlat.</p>
                <a href="{{ path('app_micro_post_add', active_category is defined and active_category != 'all' ? {'category': active_category} : {}) }}" class="group relative inline-flex items-center justify-center gap-2 px-8 py-3.5 text-sm font-bold text-white transition-all duration-200 bg-indigo-600 border border-transparent rounded-full hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-600 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                    <svg class="w-5 h-5 transition-transform group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Hemen Paylaş
                </a>
            </div>
        {% endfor %}
    </div>