{# templates/micro_post/_form.html.twig #}
{% form_theme form 'form/tailwind_layout.html.twig' %}

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    
    {# Hata varsa en tepede bir uyarı kutusu gösterelim ama form_errors(form) kullanmayalım #}
    {% if form.vars.submitted and not form.vars.valid %}
        <div class="mb-6 p-4 bg-red-100 border-l-4 border-red-500 text-red-700 rounded">
            <strong>Tüh!</strong> Lütfen formdaki eksikleri kontrol et.
            {# Debug için hataları listele #}
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <div class="space-y-4">
        {{ form_row(form.title) }} {# Bu tek satır, senin layout'undaki div, label, widget ve errors'u otomatik basar #}
        {{ form_row(form.text) }}
    </div>

    {# Paylaşım Türü (Category) Seçimi #}
    <div class="mt-6">
        {{ form_row(form.category) }}
    </div>

    {# YENİ EKLENEN EXTRA PRIVACY ALANI #}
     <div class="pt-4">
    {# items-start sayesinde kutucuk en tepedeki yazıyla aynı hizada başlar #}
    <div class="flex items-start gap-3">
        
        {# 1. Kutucuk (Widget) - Hizalama için üstten çok az boşluk (mt-1) ekledik #}
        <div class="mt-1">
            {{ form_widget(form.extraPrivacy, {'attr': {'class': 'w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 cursor-pointer'}}) }}
        </div>

        {# 2. Yazı Grubu (Label ve Açıklama) #}
        <div class="flex flex-col mt-1">
            {# Ana Etiket #}
            {{ form_label(form.extraPrivacy, null, {'label_attr': {'class': 'text-sm font-bold text-gray-700 dark:text-gray-300 cursor-pointer'}}) }}
        </div>
    </div>

    <button type="submit" class="w-full mt-6 bg-blue-600 text-white py-2 rounded-md hover:bg-blue-700 transition">
        Kaydet
    </button>
    

{{ form_end(form) }}