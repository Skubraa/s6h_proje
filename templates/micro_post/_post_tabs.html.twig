{# SEKME NAVİGASYONU ENTEGRASYONU #}
    <div class="mt-12">
        {% embed 'shared/_tabs.html.twig' %}
            {% block tabs %}
                {# PAYLAŞIMLAR SEKMESİ #}
                {% embed 'shared/_tab.html.twig' with { route: 'app_micro_post' } %}
                    {% block path %}{{ path('app_micro_post') }}{% endblock %}
                    {% block content %}
                        Tüm Paylaşımlar 
                    {% endblock %}
                {% endembed %}

                {# BEĞENİLENLER SEKMESİ (Yeni eklendi) #}
                {% embed 'shared/_tab.html.twig' with { route: 'app_micro_post_topliked' } %}
                    {% block path %}{{ path('app_micro_post_topliked') }}{% endblock %}
                    {% block content %}
                        En Çok Beğenilenler 
                    {% endblock %}
                {% endembed %}

                {# Takip Edilenler SEKMESİ #}
                {% embed 'shared/_tab.html.twig' with { route: 'app_micro_post_follows' } %}
                    {% block path %}{{ path('app_micro_post_follows') }}{% endblock %}
                    {% block content %}
                        Takip Ettiğiniz Kişiler 
                    {% endblock %}
                {% endembed %}

                {# Takipçiler SEKMESİ #}
                {% embed 'shared/_tab.html.twig' with { route: '' } %}
                    {% block path %}{% endblock %}
                    {% block content %}
                        Sizi Takip Edenler 
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    </div>