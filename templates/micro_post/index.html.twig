{# templates/micro_post/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Öğrenme Günlüğü Akışı{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto py-8 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-gray-900 transition-colors duration-300">
    
    {# Başlık Alanı #}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4 sm:gap-0 border-b pb-6 border-gray-200 dark:border-gray-700">
        <div>
            <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight">
                Öğrenme Günlüğü Akışı
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mt-2 text-lg">Neler öğrendiğini dünyayla paylaş.</p>
        </div>
        
        {# Yeni Ekle Butonu #}
        {% if is_granted('ROLE_WRITER') %}
            {# Eğer kullanıcı doğrulanmışsa (ROLE_WRITER yetkisi varsa) şık butonun görünür #}
            <a href="{{ path('app_micro_post_add') }}" 
            class="w-full sm:w-auto text-center bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold shadow-md transition-all duration-200 transform hover:-translate-y-0.5 active:scale-95 flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Yeni Ekle
            </a>
        {% else %}
            {# Eğer kullanıcı henüz doğrulanmamışsa şık ama bilgi veren bir uyarı kutusu görünür #}
            <div class="w-full p-4 bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-500 rounded-r-xl flex items-center gap-3 shadow-sm">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0116 0z"></path>
                </svg>
                <p class="text-sm font-medium text-blue-800 dark:text-blue-300">
                    Fikirlerini paylaşmak için lütfen e-posta adresini doğrula. Mail kutunu kontrol etmeyi unutma!
                </p>
            </div>
        {% endif %}
    </div>

    {# Post Listesi #}
    <div class="space-y-8">
        {% for post in posts %}
            <div class="bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-lg sm:rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden group">
                <div class="p-6 md:p-8">
                    
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-2 md:gap-0">
                        <div class="flex-1">
                            <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                                <a href="{{ path('app_micro_post_show', {id: post.id}) }}">
                                    {{ post.title }}
                                </a>
                            </h3>
                            <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400 mt-2">
                                <span class="flex items-center gap-1.5">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    {{ post.created|date('d.m.Y H:i') }}
                                </span>
                                
                                {# YORUM SAYISI: Sadece en az 1 yorum varsa gösterir #}
                                {% if post.comments|length > 0 %}
                                    <span class="flex items-center gap-1 text-indigo-500 dark:text-indigo-400 font-medium">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                                        </svg>
                                        {{ post.comments|length }} Yorum
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                        
                        <span class="hidden md:block bg-blue-50 dark:bg-gray-700 text-blue-700 dark:text-blue-200 text-xs font-semibold px-3 py-1 rounded-full border border-blue-100 dark:border-gray-600 whitespace-nowrap">
                            #günlük
                        </span>
                    </div>

                    <p class="mt-6 text-gray-700 dark:text-gray-300 leading-relaxed text-base md:text-lg">
                        {{ post.text|length > 180 ? post.text|slice(0, 180) ~ '...' : post.text }}
                    </p>

                    <div class="mt-8 pt-6 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between gap-4">
                        <a href="{{ path('app_micro_post_show', {id: post.id}) }}" 
                           class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-semibold text-sm flex items-center gap-1.5 transition-colors">
                            Devamını Oku 
                            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                        
                        <div class="flex items-center gap-3">
                            <a href="{{ path('app_micro_post_edit', {id: post.id}) }}" 
                               class="text-gray-500 dark:text-gray-400 hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors p-2 rounded-lg hover:bg-yellow-50 dark:hover:bg-gray-700"
                               title="Düzenle">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-center py-16 px-6 bg-white dark:bg-gray-800 rounded-2xl border-2 border-dashed border-gray-200 dark:border-gray-700 shadow-inner">
                <svg class="w-16 h-16 text-gray-400 dark:text-gray-600 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
                <p class="text-xl font-semibold text-gray-700 dark:text-gray-300">Henüz hiçbir şey paylaşılmamış...</p>
                <a href="{{ path('app_micro_post_add') }}" class="inline-block mt-8 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-medium shadow-md transition-colors">
                    + Hemen Paylaş
                </a>
            </div>
        {% endfor %}
    </div>

    <div class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-700 text-center text-gray-500 dark:text-gray-600 text-sm">
        <p>&copy; 2026 Sümeyye'nin Öğrenme Günlüğü. Tüm hakları saklıdır.</p>
    </div>
</div>
{% endblock %}