{# templates/micro_post/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Öğrenme Günlüğü Akışı{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8 transition-colors duration-300">
    
    {# Başlık Alanı #}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-6 border-b pb-6 border-gray-100 dark:border-gray-800">
        <div>
            <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight">
                {% if active_category is defined %}
                    {% if active_category == 'learning' %} Öğrenme Günlüğü 
                    {% elseif active_category == 'internship' %} Staj Günlüğü 
                    {% elseif active_category == 'work' %} İş Günlüğü 
                    {% elseif active_category == 'personal' %} Normal Günlük 
                    {% else %} Tüm Paylaşımlar {% endif %}
                {% else %}
                    Tüm Paylaşımlar
                {% endif %}
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mt-2 text-lg">
                {% if active_category is defined %}
                    {% if active_category == 'learning' %}Neler öğrendiğini dünyayla paylaş.
                    {% elseif active_category == 'internship' %}Stajdaki deneyimlerini ve öğrendiklerini not al.
                    {% elseif active_category == 'work' %}İş hayatındaki başarılarını ve gününü paylaş.
                    {% elseif active_category == 'personal' %}Bugün neler yaşadın? Anılarını sakla.
                    {% else %}Tüm deneyimlerini dünyayla paylaş.{% endif %}
                {% else %}
                    Tüm deneyimlerini dünyayla paylaş.
                {% endif %}
            </p>
        </div>
        
        {# Yeni Ekle Butonu #}
        {% if is_granted('ROLE_WRITER') %}
            {# Eğer kullanıcı doğrulanmışsa (ROLE_WRITER yetkisi varsa) şık butonun görünür #}
            <a href="{{ path('app_micro_post_add', active_category is defined and active_category != 'all' ? {'category': active_category} : {}) }}" 
            class="group w-full sm:w-auto flex items-center justify-center gap-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
            <svg class="w-5 h-5 transition-transform duration-300 group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Yeni Ekle
            </a>
        {% else %}
            {# Eğer kullanıcı henüz doğrulanmamışsa şık ama bilgi veren bir uyarı kutusu görünür #}
            <div class="w-full p-4 bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-500 rounded-r-xl flex items-center gap-3 shadow-sm">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0116 0z"></path>
                </svg>
                <p class="text-sm font-medium text-blue-800 dark:text-blue-300">
                    Fikirlerini paylaşmak için lütfen e-posta adresini doğrula. Mail kutunu kontrol etmeyi unutma!
                </p>
            </div>
        {% endif %}
    </div>

    {# KATEGORİ NAVİGASYONU #}
    <div class="mb-8 flex gap-3 overflow-x-auto pb-4 scrollbar-hide">
        <a href="{{ path('app_micro_post') }}" class="px-5 py-2.5 rounded-xl text-sm font-bold whitespace-nowrap transition-all shadow-sm border {% if active_category is not defined or active_category == 'all' %}bg-indigo-600 text-white border-indigo-600 shadow-indigo-200{% else %}bg-white text-gray-600 border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700{% endif %}">Tümü</a>
        <a href="{{ path('app_micro_post_category', {category: 'learning'}) }}" class="px-5 py-2.5 rounded-xl text-sm font-bold whitespace-nowrap transition-all shadow-sm border {% if active_category is defined and active_category == 'learning' %}bg-blue-600 text-white border-blue-600 shadow-blue-200{% else %}bg-white text-gray-600 border-gray-200 hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700{% endif %}">📘 Öğrenme Günlüğü</a>
        <a href="{{ path('app_micro_post_category', {category: 'internship'}) }}" class="px-5 py-2.5 rounded-xl text-sm font-bold whitespace-nowrap transition-all shadow-sm border {% if active_category is defined and active_category == 'internship' %}bg-purple-600 text-white border-purple-600 shadow-purple-200{% else %}bg-white text-gray-600 border-gray-200 hover:border-purple-300 hover:bg-purple-50 hover:text-purple-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700{% endif %}">💼 Staj Günlüğü</a>
        <a href="{{ path('app_micro_post_category', {category: 'work'}) }}" class="px-5 py-2.5 rounded-xl text-sm font-bold whitespace-nowrap transition-all shadow-sm border {% if active_category is defined and active_category == 'work' %}bg-emerald-600 text-white border-emerald-600 shadow-emerald-200{% else %}bg-white text-gray-600 border-gray-200 hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700{% endif %}">🏢 İş Günlüğü</a>
        <a href="{{ path('app_micro_post_category', {category: 'personal'}) }}" class="px-5 py-2.5 rounded-xl text-sm font-bold whitespace-nowrap transition-all shadow-sm border {% if active_category is defined and active_category == 'personal' %}bg-orange-500 text-white border-orange-500 shadow-orange-200{% else %}bg-white text-gray-600 border-gray-200 hover:border-orange-300 hover:bg-orange-50 hover:text-orange-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700{% endif %}">📓 Normal Günlük</a>
    </div>

    {# SEKME NAVİGASYONU #}
    {{ include('micro_post/_post_tabs.html.twig') }}
    {# Post Listesi Modülü #}
    {{ include('micro_post/_post_list.html.twig', {posts: posts}) }}
    
</div>
{% endblock %}