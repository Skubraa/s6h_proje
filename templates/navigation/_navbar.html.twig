{# --- ŞIK ÜST MENÜ (NAVBAR) BAŞLANGICI --- #}
        <nav class="bg-white dark:bg-gray-800 shadow-sm border-b border-gray-200 dark:border-gray-700">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between h-16 items-center">
                    
                    {# Sol Taraf: Logo / Site Adı #}
                    <div class="flex-shrink-0 flex items-center">
                        <a href="{{ path('app_micro_post') }}" class="text-xl font-extrabold text-blue-600 dark:text-blue-400 hover:text-blue-700 transition flex items-center gap-2">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                            Günlük Akışı
                        </a>
                    </div>

                    {# Sağ Taraf: Menüler ve Kullanıcı Bilgileri #}
                    <div class="flex items-center gap-4">

                        {# Günlüğüm Dropdown (Sağ tarafta, kullanıcının solunda) #}
                        <div class="relative flex items-center pr-4 border-r border-gray-200 dark:border-gray-700" x-data="{ diaryOpen: false }">
                            <button @click="diaryOpen = !diaryOpen" type="button" class="flex items-center gap-2 text-gray-700 dark:text-gray-300 font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition focus:outline-none">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                                Günlüğüm
                                <svg class="w-4 h-4 transition-transform duration-200" :class="{ 'rotate-180': diaryOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>

                            <div x-show="diaryOpen" 
                                @click.away="diaryOpen = false"
                                x-transition:enter="transition ease-out duration-100"
                                x-transition:enter-start="transform opacity-0 scale-95"
                                x-transition:enter-end="transform opacity-100 scale-100"
                                x-transition:leave="transition ease-in duration-75"
                                x-transition:leave-start="transform opacity-100 scale-100"
                                x-transition:leave-end="transform opacity-0 scale-95"
                                class="absolute right-4 top-full mt-3 w-48 rounded-2xl shadow-2xl py-2 bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 z-50 border border-gray-100 dark:border-gray-700"
                                style="display: none;">
                                
                                <a href="{{ path('app_micro_post_category', {category: 'learning'}) }}" class="block px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors">
                                    📘 Öğrenme Günlüğüm
                                </a>
                                <a href="{{ path('app_micro_post_category', {category: 'internship'}) }}" class="block px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors">
                                    💼 Staj Günlüğüm
                                </a>
                                <a href="{{ path('app_micro_post_category', {category: 'work'}) }}" class="block px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors">
                                    🏢 İş Günlüğüm
                                </a>
                                <a href="{{ path('app_micro_post_category', {category: 'personal'}) }}" class="block px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors">
                                    📓 Normal Günlük
                                </a>
                            </div>
                        </div>

                        {# Kullanıcı Giriş Yapmışsa #}
                        {% if app.user %}
                            <div class="relative flex items-center gap-4 border-r border-gray-200 dark:border-gray-700 pr-4" x-data="{ open: false }">
                                
                                {# Tetikleyici Buton (İsim ve Avatar) #}
                                <button @click="open = !open" type="button" class="flex items-center gap-3 focus:outline-none group">
                                    <span class="hidden sm:block text-sm text-gray-700 dark:text-gray-300 font-medium group-hover:text-blue-600 dark:group-hover:text-blue-400 transition">
                                        Merhaba, <strong>{{ app.user.userProfile.name|default(app.user.email) }}</strong>
                                    </span>
                                    
                                    {# YENİ: Dinamik Avatar Modülümüzü Çağırıyoruz  #}
                                    {{ include('shared/_avatar.html.twig', {'size': 9, profile: app.user.userProfile}) }}
                                    
                                </button>

                                {# Açılır Menü (Dropdown) #}
                                <div x-show="open" 
                                    @click.away="open = false"
                                    x-transition:enter="transition ease-out duration-100"
                                    x-transition:enter-start="transform opacity-0 scale-95"
                                    x-transition:enter-end="transform opacity-100 scale-100"
                                    x-transition:leave="transition ease-in duration-75"
                                    x-transition:leave-start="transform opacity-100 scale-100"
                                    x-transition:leave-end="transform opacity-0 scale-95"
                                    class="absolute right-0 top-full mt-3 w-52 rounded-2xl shadow-2xl py-2 bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 z-50 border border-gray-100 dark:border-gray-700"
                                    style="display: none;">
                                    
                                    {# Profilim (ID tabanlı ana profil sayfası) #}
                                    <a href="{{ path('app_profile', {id: app.user.id}) }}" class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors">
                                        <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        Profilimi Gör
                                    </a>

                                    {# Yeni Paylaşım Ekle (Hızlı Erişim) #}
                                    {% if is_granted('ROLE_WRITER') %}
                                        <a href="{{ path('app_micro_post_add') }}" class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors">
                                            <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                            </svg>
                                            Yeni Paylaşım
                                        </a>
                                    {% endif %}

                                    {# Profil Ayarları Linki #}
                                    <a href="{{ path('app_settings_profile') }}" class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors">
                                        <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                        Profil Ayarları
                                    </a>

                                    <div class="border-t border-gray-100 dark:border-gray-700 my-1"></div>

                                    {# Çıkış Yap Linki #}
                                    <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 py-3 text-sm text-red-600 font-bold hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                                        Çıkış Yap
                                    </a>
                                </div>
                            </div>

                        {# Kullanıcı Giriş Yapmamışsa #}
                        {% else %}
                            <div class="flex items-center gap-2 border-r border-gray-200 dark:border-gray-700 pr-4">
                                <a href="{{ path('app_login') }}" class="px-4 py-2 text-sm font-bold text-indigo-600 bg-indigo-50 hover:bg-indigo-100 rounded-lg dark:bg-indigo-900/30 dark:text-indigo-400 dark:hover:bg-indigo-900/50 transition">
                                    Giriş Yap
                                </a>
                            </div>
                        {% endif %}

                        {# Tema Değiştirme Butonu (Senin kodunu buraya menüye taşıdım) #}
                        <button id="theme-toggle" type="button" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-lg text-sm p-2 transition-all">
                            {# Ay İkonu #}
                            <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
                            {# Güneş İkonu #}
                            <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
                        </button>

                    </div>
                </div>
            </div>
        </nav>
        {# --- ŞIK ÜST MENÜ (NAVBAR) BİTİŞİ --- #}