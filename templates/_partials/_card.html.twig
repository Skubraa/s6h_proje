{# templates/_partials/_card.html.twig #}
<div style="border-left: 5px solid #007bff; background: #e9ecef; padding: 15px; margin: 10px 0; border-radius: 5px;">
    <small>ID: {{ id }}</small>
    <h3 style="margin: 5px 0;">{{ icerik|upper }}</h3>
    <p>Bu mesajın uzunluğu: {{ icerik|length }} karakter.</p>
</div>