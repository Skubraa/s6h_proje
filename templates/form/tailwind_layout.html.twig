{# templates/form/tailwind_layout.html.twig #}
{% use 'form_div_layout.html.twig' %}

{# 1. FORM ROW: Hataların görünmesi için en kritik blok #}
{% block form_row %}
    <div class="mb-6 flex flex-col">
        {{ form_label(form) }}
        {{ form_widget(form) }}
        {# Hataları widget'ın hemen altına, senin istediğin stille basıyoruz #}
        {{ form_errors(form) }}
    </div>
{% endblock %}

{# templates/form/tailwind_layout.html.twig #}

{% block form_errors %}
    {% if errors|length > 0 %}
        <div class="mt-2 flex flex-col gap-2 p-3 bg-red-50 dark:bg-red-900/10 border border-red-200 dark:border-red-800 rounded-lg shadow-sm">
            {% for error in errors %}
                <span class="text-red-600 dark:text-red-400 text-sm font-bold italic flex items-center gap-2">
                    {# Ekran görüntüsündeki ünlem ikonu #}
                    <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                    </svg>
                    {{ error.message }}
                </span>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}

{# 2. LABEL: Stilinde bir değişiklik yapmadım, aynen korundu #}
{% block form_label %}
    {% set label_attr = label_attr|merge({class: label_attr.class|default('') ~ ' text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2'}) %}
    {{ parent() }}
{% endblock %}

{# 3. INPUT WIDGET: Geçişler ve odaklanma efektlerin korundu #}
{% block form_widget_simple %}
    {% set error_class = errors|length > 0 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500' %}
    {% set attr = attr|merge({class: attr.class|default('') ~ ' w-full px-4 py-3 rounded-lg border bg-gray-50 dark:bg-gray-700 text-gray-900 dark:white outline-none transition duration-200 ' ~ error_class}) %}
    {{ parent() }}
{% endblock %}

{# 4. TEXTAREA WIDGET: Dikdörtgen formu korundu #}
{% block textarea_widget %}
    {% set attr = attr|merge({class: attr.class|default('') ~ ' w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition duration-200 focus:bg-white dark:focus:bg-gray-800'}) %}
    <textarea {{ block('widget_attributes') }}>{{ value }}</textarea>
{% endblock %}

