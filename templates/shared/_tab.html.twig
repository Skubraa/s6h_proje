
{% set is_active = app.request.attributes.get('_route') == route %}

<div class="relative pb-4 transition-all duration-200 shrink-0">
    <a href="{% block path %}{% endblock %}" 
       class="text-sm font-bold tracking-wide uppercase transition-colors
              {{ is_active ? 'text-indigo-600 dark:text-indigo-400' : 'text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300' }}">
        {% block content %}{% endblock %}
    </a>

    {# Aktiflik Çizgisi: Daha estetik ve ayrık durması için absolute konumlandırdım #}
    {% if is_active %}
        <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-indigo-500 dark:bg-indigo-400 rounded-full"></div>
    {% endif %}
</div>